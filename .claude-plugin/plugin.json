{
  "name": "veritaserum",
  "version": "0.2.0-rc.3",
  "description": "The case-law auditor: an async cross-family auditor checks load-bearing claims against git probes and the harness's own record, and demands persist as standing case law.",
  "author": {
    "name": "Trusty Squire"
  },
  "homepage": "https://github.com/Trusty-Squire/veritaserum",
  "license": "MIT",
  "keywords": [
    "confabulation",
    "hallucination",
    "verification",
    "case-law",
    "auditor"
  ],
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "VS_EXECUTOR=claude VS_HARNESS=claude-code node \"${CLAUDE_PLUGIN_ROOT}/dist/cli.js\" hook-stop"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "VS_EXECUTOR=claude VS_HARNESS=claude-code node \"${CLAUDE_PLUGIN_ROOT}/dist/cli.js\" hook-prompt"
          }
        ]
      }
    ]
  }
}
