{
  "name": "ser",
  "version": "0.1.0",
  "type": "module",
  "description": "A portable ground-truth layer for coding agents (P0 engine + CLI)",
  "bin": {
    "ser": "./dist/cli.js",
    "ser-mcp": "./dist/mcp.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/cli.js dist/mcp.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "ser": "tsx src/cli.ts",
    "demo": "tsx scripts/demo.ts",
    "mcp": "tsx src/mcp.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "execa": "^9.5.1",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
